---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <h3>Somerset Accountancy Services Ltd</h3>
      <p>Quality, affordable accounting services for businesses and individuals across Somerset and the surrounding area. Est. 1992.</p>
    </div>
    <div>
      <h4>Location</h4>
      <p>Somerset, England</p>
    </div>
    <div>
      <h4>Contact</h4>
      <p>
        <a href="tel:01458310020">01458 310020</a><br />
        <a href="mailto:info@somersetaccountancy.co.uk">info@somersetaccountancy.co.uk</a>
      </p>
    </div>
    <div>
      <h4>Professional indemnity</h4>
      <p>Insured with Everest Insurance (Ireland) DAC and Ascot Syndicate 1414 at Lloyd's.</p>
    </div>
  </div>
  <div class="container footer-bottom">
    <span>&copy; {year} Somerset Accountancy Services Ltd. Registered in England.</span>
    <span>Est. August 1992</span>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--colour-ink);
    color: #cbd2e3;
    padding: 4rem 0 2rem;
    margin-top: 4rem;
  }

  .site-footer h3,
  .site-footer h4 {
    color: #fff;
  }

  .site-footer p,
  .site-footer span {
    color: #cbd2e3;
    font-size: 0.92rem;
  }

  .site-footer a {
    color: #fff;
    text-decoration: underline;
    text-decoration-color: var(--colour-accent);
    text-underline-offset: 3px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 2.5rem;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin-top: 3rem;
    padding-top: 1.5rem;
    font-size: 0.85rem;
  }

  @media (max-width: 720px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
