---
const base = import.meta.env.BASE_URL; // e.g. "/somerset-accountancy/"
const url = (p: string) => (p === "/" ? base : `${base}${p.replace(/^\//, "")}`);

const links = [
  { href: url("/"), label: "Home" },
  { href: url("/services"), label: "Services" },
  { href: url("/about"), label: "About" },
  { href: url("/contact"), label: "Contact" },
];
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const norm = (h: string) => h.replace(/\/$/, "") || "/";
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={url("/")}>
      <span class="brand-mark">M&amp;Co</span>
      <span class="brand-name">Meridian Accountancy</span>
    </a>
    <nav aria-label="Primary">
      <ul>
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  "nav-link",
                  {
                    active:
                      path === norm(link.href) ||
                      (norm(link.href) !== norm(base) && path.startsWith(norm(link.href))),
                  },
                ]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <a class="button button-primary header-cta" href={url("/contact")}>Book a consultation</a>
  </div>
</header>

<style>
  .site-header {
    background: var(--colour-surface);
    border-bottom: 1px solid var(--colour-border);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 1rem 1.25rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--colour-ink);
    font-weight: 600;
  }

  .brand:hover {
    color: var(--colour-ink);
  }

  .brand-mark {
    font-family: var(--font-serif);
    background: var(--colour-ink);
    color: var(--colour-bg);
    padding: 0.4rem 0.6rem;
    border-radius: var(--radius);
    font-size: 0.95rem;
    letter-spacing: 0.02em;
  }

  .brand-name {
    font-family: var(--font-serif);
    font-size: 1.1rem;
  }

  nav {
    margin-left: auto;
  }

  nav ul {
    display: flex;
    gap: 1.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    color: var(--colour-ink-soft);
    font-size: 0.95rem;
    font-weight: 500;
    padding: 0.25rem 0;
    border-bottom: 2px solid transparent;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--colour-ink);
    border-bottom-color: var(--colour-accent);
  }

  .header-cta {
    padding: 0.55rem 1.1rem;
    font-size: 0.9rem;
  }

  @media (max-width: 820px) {
    .brand-name,
    .header-cta {
      display: none;
    }
    nav ul {
      gap: 1.25rem;
    }
  }
</style>
