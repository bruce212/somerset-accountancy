---
import Layout from "../layouts/Layout.astro";

const team = [
  {
    name: "Helena Whitcombe FCA",
    role: "Managing Partner",
    bio: "Audit and assurance specialist with 22 years' experience, including eight years as a senior manager at a top-ten firm. Sits on the ICAEW South West regional committee.",
  },
  {
    name: "Daniel Aldridge CTA",
    role: "Tax Partner",
    bio: "Chartered tax advisor focused on owner-managed businesses, R&D claims, and exit planning. Frequent speaker on entrepreneurs' relief and EMI schemes.",
  },
  {
    name: "Priya Shah ACA",
    role: "Advisory Director",
    bio: "Former CFO turned advisor. Builds the forecasts, dashboards, and lender packs that get our clients funded and keep them sleeping at night.",
  },
];

const values = [
  {
    title: "Plain English first",
    body: "Tax and accounting jargon doesn't help anyone. Every report, email, and meeting is written for the human reading it, not the regulator filing it.",
  },
  {
    title: "Fixed fees, agreed upfront",
    body: "No surprise bills. Every engagement starts with a clear scope and a fixed monthly fee, reviewed quarterly so it stays fair on both sides.",
  },
  {
    title: "Senior people, every time",
    body: "Your work isn't passed to a junior the moment it's signed. The partner who quoted you stays close to your account for the life of the engagement.",
  },
  {
    title: "Proactive, not reactive",
    body: "We flag tax-saving opportunities before year-end, not after. Quarterly check-ins are built into every engagement.",
  },
];
---

<Layout
  title="About — Meridian Accountancy"
  description="Meet the team behind Meridian Accountancy — chartered accountants and tax advisors based in Somerset."
>
  <section class="page-hero">
    <div class="container hero-grid">
      <div>
        <span class="eyebrow">About us</span>
        <h1>A practice built on long client relationships</h1>
        <p class="lede">
          Meridian was founded in 2014 by Helena Whitcombe after twelve years inside larger firms.
          The brief was simple: deliver the technical depth of a national practice, with the
          attention and continuity you only get from a smaller team.
        </p>
        <p>
          A decade on, that brief still holds. We've grown to fourteen people across our Taunton
          office, but every client still has a partner-level relationship and a direct line to the
          person doing the work.
        </p>
      </div>
      <div class="stats">
        <div><strong>2014</strong><span>Founded</span></div>
        <div><strong>14</strong><span>People</span></div>
        <div><strong>180+</strong><span>Active clients</span></div>
        <div><strong>£42m</strong><span>Client turnover advised</span></div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">Our values</span>
        <h2>Four things we won't compromise on</h2>
      </header>
      <div class="values-grid">
        {
          values.map((v) => (
            <article>
              <h3>{v.title}</h3>
              <p>{v.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="team-section">
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">The team</span>
        <h2>Meet your partners</h2>
      </header>
      <div class="team-grid">
        {
          team.map((member) => (
            <article class="team-card">
              <div class="avatar" aria-hidden="true">
                {member.name
                  .split(" ")
                  .slice(0, 2)
                  .map((w) => w[0])
                  .join("")}
              </div>
              <h3>{member.name}</h3>
              <span class="role">{member.role}</span>
              <p>{member.bio}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    background: var(--colour-surface);
    border-bottom: 1px solid var(--colour-border);
    padding: 5rem 0 4rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .lede {
    font-size: 1.15rem;
  }

  .stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .stats > div {
    background: var(--colour-bg);
    padding: 1.25rem;
    border-radius: var(--radius);
    border: 1px solid var(--colour-border);
  }

  .stats strong {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    display: block;
    color: var(--colour-ink);
  }

  .stats span {
    font-size: 0.85rem;
    color: var(--colour-ink-soft);
  }

  .section-head {
    max-width: 60ch;
    margin: 0 auto 3rem;
    text-align: center;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .values-grid article {
    background: var(--colour-surface);
    padding: 1.75rem;
    border-radius: var(--radius);
    border-left: 3px solid var(--colour-accent);
  }

  .team-section {
    background: var(--colour-surface);
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .team-card {
    background: var(--colour-bg);
    padding: 2rem;
    border-radius: var(--radius);
    border: 1px solid var(--colour-border);
  }

  .avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--colour-ink);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .role {
    color: var(--colour-accent-deep);
    font-size: 0.9rem;
    font-weight: 600;
    display: block;
    margin: -0.25rem 0 0.75rem;
  }

  @media (max-width: 800px) {
    .hero-grid,
    .values-grid,
    .team-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
