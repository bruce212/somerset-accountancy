---
import Layout from "../layouts/Layout.astro";

const values = [
  {
    title: "Quality for everyone",
    body: "We believe expert, clear, and honest accounting advice should be accessible to all — not just large companies. Whether you're a sole trader or a growing business, you get the same high standard of service.",
  },
  {
    title: "Personal approach",
    body: "You'll have a dedicated account manager who understands your business. We build long-term relationships with our clients, not transactional ones.",
  },
  {
    title: "Plain, honest advice",
    body: "Accounting and tax can be complicated — we make it simple. We explain things clearly, keep you informed, and never leave you in the dark about your finances.",
  },
  {
    title: "Profit-focused thinking",
    body: "We use the Profit First methodology to help our clients build genuinely profitable, sustainable businesses — not just meet compliance deadlines.",
  },
];

const approach = [
  {
    title: "Peace of mind",
    body: "We handle your accounting and tax obligations so you can stop worrying about HMRC deadlines and focus on what you do best.",
  },
  {
    title: "More profit",
    body: "Using the Profit First approach, we help you take control of your finances and build a business that's consistently more profitable.",
  },
  {
    title: "More time",
    body: "With your bookkeeping, payroll, and accounts in our hands, you get back valuable time to invest in growing your business or enjoying the rewards of running one.",
  },
];
---

<Layout
  title="About — Somerset Accountancy Services Ltd"
  description="Somerset Accountancy Services Ltd — quality, affordable accounting for businesses and individuals across Somerset since 1992."
>
  <section class="page-hero">
    <div class="container hero-grid">
      <div>
        <span class="eyebrow">About us</span>
        <h1>Serving Somerset businesses since 1992</h1>
        <p class="lede">
          Somerset Accountancy Services was established in August 1992 with one clear purpose:
          to deliver quality, affordable accounting services to small and medium-sized businesses
          and individual clients across Somerset and the surrounding areas.
        </p>
        <p>
          More than thirty years on, that purpose remains unchanged. We provide expert, clear,
          and honest advice — and every client has a dedicated account manager who knows their
          business inside out.
        </p>
      </div>
      <div class="stats">
        <div><strong>1992</strong><span>Established</span></div>
        <div><strong>30+</strong><span>Years' experience</span></div>
        <div><strong>SMEs</strong><span>&amp; individuals served</span></div>
        <div><strong>Somerset</strong><span>&amp; surrounding areas</span></div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">Our values</span>
        <h2>What we stand for</h2>
      </header>
      <div class="values-grid">
        {
          values.map((v) => (
            <article>
              <h3>{v.title}</h3>
              <p>{v.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="team-section">
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">What we deliver</span>
        <h2>Three things every client gets</h2>
        <p>
          We measure our success not by the number of returns filed, but by the difference we
          make to the businesses and individuals we work with.
        </p>
      </header>
      <div class="team-grid">
        {
          approach.map((item) => (
            <article class="team-card">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    background: var(--colour-surface);
    border-bottom: 1px solid var(--colour-border);
    padding: 5rem 0 4rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .lede {
    font-size: 1.15rem;
  }

  .stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .stats > div {
    background: var(--colour-bg);
    padding: 1.25rem;
    border-radius: var(--radius);
    border: 1px solid var(--colour-border);
  }

  .stats strong {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    display: block;
    color: var(--colour-ink);
  }

  .stats span {
    font-size: 0.85rem;
    color: var(--colour-ink-soft);
  }

  .section-head {
    max-width: 60ch;
    margin: 0 auto 3rem;
    text-align: center;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .values-grid article {
    background: var(--colour-surface);
    padding: 1.75rem;
    border-radius: var(--radius);
    border-left: 3px solid var(--colour-accent);
  }

  .team-section {
    background: var(--colour-surface);
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .team-card {
    background: var(--colour-bg);
    padding: 2rem;
    border-radius: var(--radius);
    border: 1px solid var(--colour-border);
  }


  @media (max-width: 800px) {
    .hero-grid,
    .values-grid,
    .team-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
