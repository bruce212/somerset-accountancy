---
import Layout from "../layouts/Layout.astro";
import TaxEstimator from "../components/TaxEstimator.svelte";
import FAQ from "../components/FAQ.svelte";

const base = import.meta.env.BASE_URL;
const url = (p: string) => `${base}${p.replace(/^\//, "")}`;

const services = [
  {
    title: "Annual accounts",
    body: "Comprehensive final accounts produced through specialist software for both limited companies and sole traders, with clear explanations of what the numbers mean.",
  },
  {
    title: "Tax returns",
    body: "Business and personal tax returns prepared accurately and on time, with expert advice integrated throughout to minimise your liability.",
  },
  {
    title: "Bookkeeping & VAT",
    body: "Monthly or quarterly bookkeeping that keeps your records up to date and ensures you meet VAT deadlines — so you can focus on running your business.",
  },
  {
    title: "Payroll",
    body: "Weekly, fortnightly, or monthly payroll processing including CIS returns and auto-enrolment pension administration, handled on your behalf.",
  },
  {
    title: "Business advice",
    body: "Expert guidance on financial decision-making, strategy, risk management, and efficiency — the kind of practical advice that helps your business grow.",
  },
  {
    title: "Cloud accounting",
    body: "One-to-one training and ongoing support to help you get the most from online accounting software, making your finances more visible and accessible.",
  },
];

const faqs = [
  {
    q: "Who do you typically work with?",
    a: "We work with small and medium-sized businesses, sole traders, partnerships, and individual clients across Somerset and the surrounding areas. Whether you're just starting out or have been trading for decades, we can help.",
  },
  {
    q: "What is the Profit First methodology?",
    a: "Profit First is a cash management approach that ensures your business is profitable from day one — rather than treating profit as whatever's left at year-end. We use it to help clients build financial habits that lead to sustainable growth.",
  },
  {
    q: "Can you take over from my current accountant?",
    a: "Yes, switching is straightforward. Once you appoint us, we handle the handover from your previous accountant and make sure there's no gap in your compliance. You don't need to do anything awkward.",
  },
  {
    q: "Do you offer ongoing support or just year-end work?",
    a: "We offer both. Many clients come to us for year-end accounts and tax returns, while others take advantage of our monthly bookkeeping, payroll, and management reporting services for year-round support.",
  },
  {
    q: "How do I get started?",
    a: "Just give us a call on 01458 310020 or send an email to info@somersetaccountancy.co.uk. We'll have a no-obligation chat about what you need and put together a clear proposal.",
  },
];
---

<Layout title="Somerset Accountancy — Accountants for Business Owners in Somerset">
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <span class="eyebrow">Somerset-based · Established 1992</span>
        <h1>Less stress. More profit. More time for what matters.</h1>
        <p class="lede">
          Somerset Accountancy Services has been delivering quality, affordable accounting to
          businesses and individuals across Somerset since 1992. We give you peace of mind,
          help you build a more profitable business, and free up your time to focus on what you
          do best.
        </p>
        <div class="cta-row">
          <a class="button button-primary" href="/contact">Get in touch</a>
          <a class="button button-ghost" href="/services">Explore our services</a>
        </div>
        <ul class="trust-row">
          <li><strong>1992</strong><span>Established</span></li>
          <li><strong>30+</strong><span>years' experience</span></li>
          <li><strong>Personal</strong><span>dedicated account manager</span></li>
        </ul>
      </div>
      <aside class="hero-card">
        <span class="eyebrow">Quick estimate</span>
        <h2>How much income tax will you pay?</h2>
        <p>A rough guide to your 2024/25 liability — adjust the figures to match your circumstances.</p>
        <TaxEstimator client:load />
      </aside>
    </div>
  </section>

  <section class="services">
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">What we do</span>
        <h2>Everything you need to stay compliant and grow</h2>
        <p>
          From annual accounts and tax returns to payroll, bookkeeping, and strategic business
          advice — we provide a complete accounting service tailored to the size and ambitions of
          your business.
        </p>
      </header>
      <div class="service-grid">
        {
          services.map((s) => (
            <article class="service">
              <h3>{s.title}</h3>
              <p>{s.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container cta-inner">
      <div>
        <h2>Ready for an accountant who truly works for your business?</h2>
        <p>
          We've been helping Somerset businesses and individuals since 1992. Get in touch for a
          no-obligation conversation about how we can help you.
        </p>
      </div>
      <a class="button button-primary" href={url("/contact")}>Start a conversation</a>
    </div>
  </section>

  <section class="faq-section">
    <div class="container faq-grid">
      <header>
        <span class="eyebrow">Frequently asked</span>
        <h2>Answers to the questions we hear most</h2>
        <p>
          Don't see your question? <a href="/contact">Get in touch</a> — we're always happy to have a chat.
        </p>
      </header>
      <FAQ items={faqs} client:visible />
    </div>
  </section>
</Layout>

<style>
  .hero {
    background: linear-gradient(180deg, var(--colour-bg) 0%, var(--colour-surface) 100%);
    padding-top: 5rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .lede {
    font-size: 1.15rem;
    max-width: 52ch;
  }

  .cta-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin: 1.5rem 0 2.5rem;
  }

  .trust-row {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 2.5rem;
    border-top: 1px solid var(--colour-border);
    padding-top: 1.5rem;
  }

  .trust-row li {
    display: flex;
    flex-direction: column;
  }

  .trust-row strong {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    color: var(--colour-ink);
  }

  .trust-row span {
    font-size: 0.85rem;
    color: var(--colour-ink-soft);
  }

  .hero-card {
    background: transparent;
  }

  .hero-card h2 {
    font-size: 1.5rem;
  }

  .section-head {
    max-width: 60ch;
    margin: 0 auto 3rem;
    text-align: center;
  }

  .service-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .service {
    background: var(--colour-surface);
    border: 1px solid var(--colour-border);
    border-radius: var(--radius);
    padding: 1.75rem;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .service:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }

  .cta-band {
    background: var(--colour-ink);
    color: #fff;
  }

  .cta-band h2 {
    color: #fff;
    margin-bottom: 0.4rem;
  }

  .cta-band p {
    color: #cbd2e3;
    margin: 0;
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
  }

  @media (max-width: 900px) {
    .hero-grid,
    .faq-grid,
    .service-grid,
    .cta-inner {
      grid-template-columns: 1fr;
    }
    .service-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .service-grid {
      grid-template-columns: 1fr;
    }
    .trust-row {
      flex-wrap: wrap;
      gap: 1.5rem;
    }
  }
</style>
