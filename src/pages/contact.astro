---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm.svelte";
---

<Layout
  title="Contact — Meridian Accountancy"
  description="Get in touch with Meridian Accountancy in Taunton, Somerset. Free 30-minute discovery calls available."
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Contact</span>
      <h1>Let's talk</h1>
      <p class="lede">
        Whether you're switching from another firm, starting your first company, or facing a
        deadline that's gone sideways — we'd like to hear from you. Discovery calls are free and
        last about thirty minutes.
      </p>
    </div>
  </section>

  <section>
    <div class="container contact-grid">
      <div class="contact-info">
        <h2>Get in touch</h2>
        <dl>
          <dt>Office</dt>
          <dd>
            14 Market Place<br />
            Taunton, Somerset<br />
            TA1 3SX
          </dd>

          <dt>Telephone</dt>
          <dd><a href="tel:+441823000000">01823 000 000</a></dd>

          <dt>Email</dt>
          <dd>
            <a href="mailto:hello@meridian-accountancy.co.uk">hello@meridian-accountancy.co.uk</a>
          </dd>

          <dt>Hours</dt>
          <dd>
            Monday – Friday<br />
            08:30 – 17:30
          </dd>
        </dl>

        <div class="info-card">
          <h3>Switching to us?</h3>
          <p>
            Changing accountant is straightforward. Once you've appointed us, we handle the
            professional clearance and document handover with your current firm — you don't have to
            do anything awkward.
          </p>
        </div>
      </div>

      <div class="form-wrap">
        <h2>Send us an enquiry</h2>
        <p>We aim to respond within four working hours.</p>
        <ContactForm client:load />
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    background: var(--colour-surface);
    border-bottom: 1px solid var(--colour-border);
    padding: 5rem 0 4rem;
  }

  .lede {
    max-width: 60ch;
    font-size: 1.1rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
  }

  dl {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.5rem 1.5rem;
    margin: 1.5rem 0 2.5rem;
  }

  dt {
    font-weight: 600;
    color: var(--colour-ink);
  }

  dd {
    margin: 0;
    color: var(--colour-ink-soft);
  }

  .info-card {
    background: var(--colour-surface);
    border: 1px solid var(--colour-border);
    border-left: 3px solid var(--colour-accent);
    padding: 1.5rem;
    border-radius: var(--radius);
  }

  .info-card h3 {
    margin-top: 0;
  }

  .form-wrap {
    background: var(--colour-surface);
    padding: 2.5rem;
    border-radius: var(--radius);
    border: 1px solid var(--colour-border);
  }

  @media (max-width: 800px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
