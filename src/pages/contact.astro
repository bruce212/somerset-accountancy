---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm.svelte";
---

<Layout
  title="Contact — Somerset Accountancy Services Ltd"
  description="Get in touch with Somerset Accountancy Services — call 01458 310020 or email info@somersetaccountancy.co.uk."
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Contact</span>
      <h1>Let's talk</h1>
      <p class="lede">
        Whether you're looking for a new accountant, want to find out more about a specific
        service, or just have a question — we'd love to hear from you. Get in touch and we'll
        get back to you promptly.
      </p>
    </div>
  </section>

  <section>
    <div class="container contact-grid">
      <div class="contact-info">
        <h2>Get in touch</h2>
        <dl>
          <dt>Telephone</dt>
          <dd><a href="tel:01458310020">01458 310020</a></dd>

          <dt>Email</dt>
          <dd>
            <a href="mailto:info@somersetaccountancy.co.uk">info@somersetaccountancy.co.uk</a>
          </dd>

          <dt>Location</dt>
          <dd>Somerset, England</dd>

          <dt>Hours</dt>
          <dd>
            Monday – Friday<br />
            09:00 – 17:00
          </dd>
        </dl>

        <div class="info-card">
          <h3>Switching to us?</h3>
          <p>
            Changing accountant is simpler than you think. Once you appoint us, we handle the
            handover from your previous accountant and make sure there's no gap in your
            compliance — you don't have to do anything awkward.
          </p>
        </div>
      </div>

      <div class="form-wrap">
        <h2>Send us an enquiry</h2>
        <p>We aim to get back to you the same working day.</p>
        <ContactForm client:load />
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    background: var(--colour-surface);
    border-bottom: 1px solid var(--colour-border);
    padding: 5rem 0 4rem;
  }

  .lede {
    max-width: 60ch;
    font-size: 1.1rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
  }

  dl {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.5rem 1.5rem;
    margin: 1.5rem 0 2.5rem;
  }

  dt {
    font-weight: 600;
    color: var(--colour-ink);
  }

  dd {
    margin: 0;
    color: var(--colour-ink-soft);
  }

  .info-card {
    background: var(--colour-surface);
    border: 1px solid var(--colour-border);
    border-left: 3px solid var(--colour-accent);
    padding: 1.5rem;
    border-radius: var(--radius);
  }

  .info-card h3 {
    margin-top: 0;
  }

  .form-wrap {
    background: var(--colour-surface);
    padding: 2.5rem;
    border-radius: var(--radius);
    border: 1px solid var(--colour-border);
  }

  @media (max-width: 800px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
