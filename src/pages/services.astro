---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL;
const url = (p: string) => `${base}${p.replace(/^\//, "")}`;

const sectors = [
  {
    name: "Small & medium businesses",
    body: "Limited companies and partnerships of all sizes. We handle your compliance so you can concentrate on running and growing your business.",
  },
  {
    name: "Sole traders & freelancers",
    body: "Straightforward, affordable accounting for the self-employed. We keep your books tidy, your tax returns on time, and your costs down.",
  },
  {
    name: "Individuals & personal tax",
    body: "Personal tax returns, capital gains, rental income, and HMRC queries — handled accurately and with minimal fuss.",
  },
  {
    name: "Start-ups & new businesses",
    body: "Just starting out? We help new businesses get their accounting right from day one, with practical advice on structure, record-keeping, and staying compliant.",
  },
];

const services = [
  {
    title: "Annual accounts",
    points: [
      "Final accounts for limited companies and sole traders",
      "Produced through specialist accounting software",
      "Filed with Companies House and HMRC",
      "Clear explanations of what the numbers mean for you",
    ],
  },
  {
    title: "Tax returns",
    points: [
      "Business and personal self-assessment tax returns",
      "Expert tax advice integrated with accounts production",
      "Corporation tax computations and CT600 filing",
      "Capital gains tax and rental income reporting",
      "VAT registration and Making Tax Digital compliance",
    ],
  },
  {
    title: "Bookkeeping & VAT",
    points: [
      "Monthly or quarterly bookkeeping",
      "VAT return preparation and filing",
      "Making Tax Digital (MTD) compliant record-keeping",
      "Management reports to help you monitor performance",
    ],
  },
  {
    title: "Payroll",
    points: [
      "Weekly, fortnightly, or monthly payroll processing",
      "RTI submissions to HMRC",
      "CIS (Construction Industry Scheme) returns",
      "Auto-enrolment pension administration",
    ],
  },
  {
    title: "Company secretarial",
    points: [
      "Maintaining statutory company records",
      "Confirmation statement and Companies House filings",
      "Director appointments and changes",
      "Share allotments and company formation",
    ],
  },
  {
    title: "Business advice",
    points: [
      "Financial decision-making support",
      "Business strategy and risk management guidance",
      "Profit First methodology coaching",
      "Cashflow management and forecasting",
    ],
  },
  {
    title: "Fee protection insurance",
    points: [
      "Cover for HMRC tax enquiry costs",
      "Protection if selected for investigation or audit",
      "Representation and support throughout any enquiry",
    ],
  },
  {
    title: "Cloud accounting",
    points: [
      "One-to-one training on online accounting software",
      "Help transitioning from paper or spreadsheet records",
      "Ongoing support to get the most from your software",
      "Real-time visibility of your business finances",
    ],
  },
];
---

<Layout
  title="Services — Somerset Accountancy Services Ltd"
  description="Accounts, tax returns, bookkeeping, payroll, company secretarial, and business advice for businesses and individuals across Somerset."
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Services</span>
      <h1>Everything your business needs to thrive.</h1>
      <p class="lede">
        From annual accounts and tax returns to payroll, cloud accounting, and strategic business
        advice — Somerset Accountancy Services provides a complete, affordable service for
        businesses and individuals across Somerset. Every client gets a dedicated account manager
        and unlimited access to their team.
      </p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="services-list">
        {
          services.map((s) => (
            <article>
              <h2>{s.title}</h2>
              <ul>
                {s.points.map((p) => (
                  <li>{p}</li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="sectors">
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">Who we work with</span>
        <h2>Serving businesses and individuals of all sizes</h2>
        <p>
          Whether you're just starting out or have been trading for years, we have the knowledge
          and experience to support you at every stage.
        </p>
      </header>
      <div class="sector-grid">
        {
          sectors.map((s) => (
            <article class="sector">
              <h3>{s.name}</h3>
              <p>{s.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container cta-inner">
      <h2>Not sure which service you need?</h2>
      <a class="button button-primary" href="/contact">Get in touch for a free chat</a>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    background: var(--colour-surface);
    border-bottom: 1px solid var(--colour-border);
    padding: 5rem 0 4rem;
  }

  .lede {
    font-size: 1.1rem;
    max-width: 60ch;
  }

  .services-list {
    display: grid;
    gap: 2.5rem;
  }

  .services-list article {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 2rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--colour-border);
  }

  .services-list article:last-child {
    border-bottom: none;
  }

  .services-list h2 {
    margin: 0;
  }

  .services-list ul {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--colour-ink-soft);
  }

  .services-list li {
    padding: 0.25rem 0;
  }

  .section-head {
    max-width: 60ch;
    margin: 0 auto 3rem;
    text-align: center;
  }

  .sectors {
    background: var(--colour-surface);
  }

  .sector-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .sector {
    background: var(--colour-bg);
    padding: 1.75rem;
    border-radius: var(--radius);
    border: 1px solid var(--colour-border);
  }

  .cta-band {
    background: var(--colour-ink);
  }

  .cta-band h2 {
    color: #fff;
    margin: 0;
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  @media (max-width: 720px) {
    .services-list article,
    .sector-grid,
    .cta-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
